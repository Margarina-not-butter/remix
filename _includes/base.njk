---
title: "RE:mix"
---
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ '/static/styles.css' | url }}">
    <link rel="stylesheet" href="{{ '/static/switch.css' | url }}">
    <script src="{{ '/static/theme.js' | url }}" defer></script>
</head>
<body>
    <noscript>
        <style>
            .switch {
                display: none;
            }
        </style>
    </noscript>
    
    <div id="evHelper">
        <aside>
            <header>
                <h1>{{ translations[locale].site_title }}</h1>
                <p>{{ translations[locale].site_subtitle }}</p>
                <p>{{ translations[locale].version }}</p>
                
                <label class="switch">
                    <input type="checkbox" />
                    <span class="slider"></span>
                    <img
                    class="off"
                    src="data:image/jpeg;base64,"
                    />
                    <img
                    class="on"
                    src="data:image/jpeg;base64,"
                    />
                </label>
                
                <div class="lang-switcher">
                    <a href="{{ page.url | replace('/' + locale + '/', '/en/') | url }}" class="lang-btn {% if locale == 'en' %}active{% endif %}">EN</a>
                    <span class="lang-divider">|</span>
                    <a href="{{ page.url | replace('/' + locale + '/', '/pt/') | url }}" class="lang-btn {% if locale == 'pt' %}active{% endif %}">PT</a>
                </div>
            </header>
            
            <p>{{ translations[locale].links_header }}</p>

            <p><a href="{{ ('/' + locale + '/') | url }}">{{ translations[locale].home_nav }}</a></p>
            <p class="last"><a href="https://www.youtube.com/@uwontbelieveitsnotbutter">{{ translations[locale].youtube_nav }}</a></p>
            
            <p>{{ translations[locale].book_header }}</p>

            <p><a href="{{ ('/' + locale + '/rules/') | url }}">{{ translations[locale].rules_nav }}</a></p>
            <p><a href="{{ ('/' + locale + '/spawn-protection/') | url }}">{{ translations[locale].spawn_protection_nav }}</a></p>
            
            <footer>
                <p><a>{{ translations[locale].by_margarina | safe }}</a></p>
            </footer>
        </aside>
        <main>
            {{ content | safe }}
        </main>
    </div>
</body>
</html>